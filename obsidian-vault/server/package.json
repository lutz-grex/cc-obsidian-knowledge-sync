{
  "name": "obsidian-vault-mcp",
  "version": "1.0.0",
  "description": "MCP server for Obsidian vault operations — read, write, search, link graph, team knowledge management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "obsidian-vault-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "bun dist/index.js",
    "dev": "tsc --watch",
    "setup": "bun install && bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  },
  "license": "MIT"
}
